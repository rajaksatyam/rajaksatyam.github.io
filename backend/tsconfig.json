{
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./dist",
    "typeRoots": ["./node_modules/@types"],

    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "types": ["node","express"],

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "tests/**/*",
    "vitest.config.ts",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}